{
  "expo": {
    "name": "finapp",
    "slug": "finapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "finapp",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08090f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.anomalyco.finapp",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Usamos Face ID para proteger el acceso a la app y tus datos financieros."
      }
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
